# Used by docker-compose.yml. Copy to .env and edit.

# === Database ===
# Either provide a full DATABASE_URL...
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?schema=public

# ...or let compose construct one from these (defaults to local postgres
# service in docker-compose.yml).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ismael_dev

# === Server ===
# Required: admin password for /admin
ADMIN_PASSWORD=change-me-long-random-string

# Max upload size (MB)
MAX_UPLOAD_MB=8

# Comma-separated origins allowed to call the API. Set this when the
# frontend is on a different domain than the API.
CORS_ORIGIN=

# === Frontend ===
# Host port for the nginx-served frontend
HTTP_PORT=8080

# Build-time API URL baked into the frontend bundle. Leave empty to use
# relative paths via the nginx proxy. Set to an absolute URL when the
# frontend is deployed separately from the API:
#   VITE_API_URL=https://server-production-9e07.up.railway.app
VITE_API_URL=
