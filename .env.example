# Used by docker-compose.yml. Copy to .env and edit.

# Postgres credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ismael_dev

# Admin password for /admin (required)
ADMIN_PASSWORD=change-me-long-random-string

# Max upload size (MB)
MAX_UPLOAD_MB=8

# Host port for the frontend (nginx)
HTTP_PORT=8080
