# Postgres connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ismael_dev?schema=public"

# Server port (frontend Vite proxies /api and /uploads to this)
PORT=4000

# Comma-separated origins allowed to call the API (leave empty to allow same-origin only)
CORS_ORIGIN=http://localhost:3000

# Max upload size in MB
MAX_UPLOAD_MB=8

# Admin password — required to access /admin and manage uploads.
# Generate something strong, e.g.:  openssl rand -hex 24
ADMIN_PASSWORD=change-me-long-random-string
